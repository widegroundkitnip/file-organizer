    {
      "id": "rule-large-videos",
      "name": "Large video files",
      "enabled": false,
      "priority": 20,
      "filter": {
        "type": "all_of",
        "values": [
          {
            "type": "extension",
            "values": [
              "mp4",
              "mov",
              "mkv",
              "avi",
              "webm"
            ],
            "value": null
          },
          {
            "type": "size_gt",
            "values": null,
            "value": 500000000
          }
        ],
        "value": null
      },
      "destination_template": "LargeFiles/Videos/{name}.{ext}",
      "conflict_mode": "rename",
      "action": "move",
      "tags": [
        "large",
        "videos"
      ]
    },
