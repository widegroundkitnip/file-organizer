{
  "rules": [
    {
      "id": "rule-protected-env",
      "name": "Protected env files",
      "enabled": false,
      "priority": 1,
      "filter": {
        "type": "extension",
        "values": [
          "env",
          "ini",
          "cfg",
          "toml"
        ],
        "value": null
      },
      "destination_template": "{parent}/{name}.{ext}",
      "conflict_mode": "skip",
      "action": "move",
      "tags": [
        "protected"
      ]
    },
    {
      "id": "rule-keep-tagged",
      "name": "Keep tagged files",
      "enabled": false,
      "priority": 2,
      "filter": {
        "type": "name_contains",
        "values": [
          "KEEP"
        ],
        "value": null
      },
      "destination_template": "{parent}/{name}.{ext}",
      "conflict_mode": "skip",
      "action": "move",
      "tags": [
        "protected"
      ]
    },
    {
