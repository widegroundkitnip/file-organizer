[
  {
    "id": "rule-protected-env",
    "name": "Protected env files",
    "enabled": false,
    "priority": 1,
    "filter": {
      "type": "extension",
      "values": [
        "env",
        "ini",
        "cfg",
        "toml"
      ]
    },
    "destination_template": "{parent}/{name}.{ext}",
    "conflict_mode": "skip",
    "tags": [
      "protected"
    ]
  },
  {
    "id": "rule-keep-tagged",
    "name": "Keep tagged files",
    "enabled": false,
    "priority": 2,
    "filter": {
      "type": "name_contains",
      "values": [
        "KEEP"
      ]
    },
    "destination_template": "{parent}/{name}.{ext}",
    "conflict_mode": "skip",
    "tags": [
      "protected"
    ]
  },
  {
    "id": "rule-screenshots",
    "name": "Screenshots",
    "enabled": false,
    "priority": 10,
    "filter": {
      "type": "any_of",
      "conditions": [
        {
          "type": "name_contains",
          "values": [
            "Screenshot"
          ]
        },
        {
          "type": "name_contains",
          "values": [
            "Sk\u00e4rmbild"
          ]
        }
      ]
    },
    "destination_template": "Images/Screenshots/{year}/{month}/{name}.{ext}",
    "conflict_mode": "rename",
    "tags": [
      "images",
      "screenshots"
    ]
  },
  {
    "id": "rule-camera-photos",
    "name": "Camera photos",
    "enabled": false,
    "priority": 11,
    "filter": {
      "type": "any_of",
      "conditions": [
        {
          "type": "name_contains",
          "values": [
            "IMG_"
          ]
        },
        {
          "type": "name_contains",
          "values": [
            "DSC_"
          ]
        }
      ]
    },
    "destination_template": "Images/Camera/{year}/{month}/{name}.{ext}",
    "conflict_mode": "rename",
    "tags": [
      "images",
      "camera"
    ]
  },
  {
    "id": "rule-large-videos",
    "name": "Large video files",
    "enabled": false,
    "priority": 20,
    "filter": {
      "type": "all_of",
      "conditions": [
        {
          "type": "extension",
          "values": [
            "mp4",
            "mov",
            "mkv",
            "avi",
            "webm"
          ]
        },
        {
          "type": "size_gt",
          "value": 500000000
        }
      ]
    },
    "destination_template": "LargeFiles/Videos/{name}.{ext}",
    "conflict_mode": "rename",
    "tags": [
      "large",
      "videos"
    ]
  },
  {
    "id": "rule-large-archives",
    "name": "Large archives",
    "enabled": false,
    "priority": 21,
    "filter": {
      "type": "all_of",
      "conditions": [
        {
          "type": "extension",
          "values": [
            "zip",
            "rar",
            "7z",
            "tar",
            "gz"
          ]
        },
        {
          "type": "size_gt",
          "value": 500000000
        }
      ]
    },
    "destination_template": "LargeFiles/Archives/{name}.{ext}",
    "conflict_mode": "rename",
    "tags": [
      "large",
      "archives"
    ]
  },
