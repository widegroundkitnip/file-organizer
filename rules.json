{
  "rules": [
    {
      "id": "33b0b138-0e2b-4a09-86f7-5848f7b97eed",
      "name": "Protected Files",
      "enabled": true,
      "priority": 0,
      "filter": {
        "type": "extension",
        "values": [
          "env",
          "ini",
          "cfg",
          "toml",
          "gitignore",
          "gitattributes"
        ],
        "value": null
      },
      "destination_template": "",
      "conflict_mode": "skip",
      "action": "skip",
      "tags": [
        "protected"
      ]
    },
    {
      "id": "af2250cd-b120-4160-a322-60e7ee15d2eb",
      "name": "Keep Tagged",
      "enabled": true,
      "priority": 1,
      "filter": {
        "type": "name_contains",
        "values": [
          "KEEP",
          "TODO",
          "WIP",
          "DRAFT"
        ],
        "value": null
      },
      "destination_template": "",
      "conflict_mode": "skip",
      "action": "skip",
      "tags": [
        "protected"
      ]
    },
    {
